import random

def InArr(rows, cols):
    a = [[0] * cols for _ in range(rows)]
    for i in range(rows):
        for j in range(cols):
            a[i][j] = random.randint(-50, 50)
    return a

def OutArr(rows, cols, a):
    for i in range(rows):
        for j in range(cols):
            print(a[i][j], end='\t')
        print()

def zero_positives(arr):
    for i in range(len(arr)):
        if arr[i] > 0:
            arr[i] = 0
def process_col(a, col_idx, total_rows):
    if 0 <= col_idx < len(a[0]):
        column = [a[i][col_idx] for i in range(total_rows)]
        zero_positives(column)
        for i in range(total_rows):
            a[i][col_idx] = column[i]
    else:
        print(f"Ошибка: столбец {col_idx} выходит за границы")

rows = int(input("Количество строк: "))
cols = int(input("Количество столбцов: "))
n_idx = int(input("Индекс первого столбца для обработки (n): "))
k_idx = int(input("Индекс второго столбца для обработки (k): "))

matrix = InArr(rows, cols)
print("Исходная матрица:")
OutArr(rows, cols, matrix)

process_col(matrix, n_idx, rows)
process_col(matrix, k_idx, rows)

print(f"\nМатрица после обнуления положительных в столбцах {n_idx} и {k_idx}:")
OutArr(rows, cols, matrix)
