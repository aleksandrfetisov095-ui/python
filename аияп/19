import random

def InArr(n, m):
    a = [[0] * m for _ in range(n)]
    for i in range(n):
        for j in range(m):
            a[i][j] = random.randint(-10, 10) # Маленькие числа, чтобы не было огромных результатов
    return a

def OutArr(n, m, a):
    for i in range(n):
        for j in range(m):
            print(a[i][j], end='\t')
        print()

def multiply_arr(arr, q):
    for i in range(len(arr)):
        arr[i] = arr[i] * q
    return arr

n = int(input("Строки: "))
m = int(input("Столбцы: "))

matrix = InArr(n, m)
print("Исходная матрица:")
OutArr(n, m, matrix)

for i in range(n):
    multiplier = i + 1  # Номер строки (1, 2, 3...)
    matrix[i] = multiply_arr(matrix[i], multiplier)

print("\nМатрица после умножения строк на их номер:")
OutArr(n, m, matrix)
