import random

def InArr(n, m):
    a = [[0] * m for _ in range(n)]
    for i in range(n):
        for j in range(m):
            a[i][j] = random.randint(-50, 50)
    return a

def OutArr(n, m, a):
    for i in range(n):
        for j in range(m):
            print(a[i][j], end='\t')
        print()

def sum_above_main_diag(matrix, size):
    total = 0
    for i in range(size):
        for j in range(i + 1, size):
            total += matrix[i][j]
    return total

n = int(input("Размер квадратной матрицы N: "))
m = n 

matrix = InArr(n, m)
print("Квадратная матрица:")
OutArr(n, m, matrix)

result = sum_above_main_diag(matrix, n)
print(f"\nСумма элементов выше главной диагонали: {result}")
