import random

def InArr(n, m):
    a = [[0] * m for _ in range(n)]
    for i in range(n):
        for j in range(m):
            a[i][j] = random.randint(-50, 50)
    return a

def OutArr(n, m, a):
    for i in range(n):
        for j in range(m):
            print(a[i][j], end='\t')
        print()

def average_1d(arr):
    total = 0
    for x in arr:
        total += x
    return total / len(arr)

n = int(input("Размер квадратной матрицы N: "))
m = n

matrix = InArr(n, m)
print("Квадратная матрица:")
OutArr(n, m, matrix)

sec_diag = [matrix[i][n - 1 - i] for i in range(n)]

avg = average_1d(sec_diag)
print(f"\nЭлементы побочной диагонали: {sec_diag}")
print(f"Среднее арифметическое побочной диагонали: {avg:.2f}")
