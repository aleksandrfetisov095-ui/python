import struct
import math

# f - файловая переменная
# filename - название файла
# n - кол чисел (определяет пользователь)
# i - параметр цикла
# ai - основная формула
# positive_count - счетчик положительных значений
# s - байты прочитанные из файла
# value - расшифровка файла

n = int(input("Сколько компонентов записать? "))
filename = 'data.bin'

f = open(filename, 'wb')
for i in range(n):
    ai = (i + 1) ** 2 * math.sin((i * math.pi) / 10)
    f.write(struct.pack('f', ai))
f.close()

print("Файл создан.")

positive_count = 0
f = open(filename, 'rb')

for i in range(n):
    s = f.read(4)
    value = struct.unpack('f', s)[0]

    if value >= 0:
        positive_count += 1

    print(f"Значение: {value:.2f}")
f.close()
print(f"\nПоложительных значений: {positive_count}")
