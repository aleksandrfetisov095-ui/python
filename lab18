"""
Лабораторная работа № 18, Вариант 26
Разработать пакет для обработки строк, позволяющий:
1) определить самое длинное слово в строке, если слов с максимальной длиной несколько – вывести все;
2) определить слово, которое чаще всех встречается в двух строках;
3) определить общие для двух строк слова;
4) удалить из строки слова-палиндромы
"""

from paket import *

print('''Выберите действие:
- [1] Найти самое длинное слово(я) в строке
- [2] Найти слово, встречающееся чаще всего в двух строках
- [3] Найти общие слова в двух строках
- [4] Удалить слова-палиндромы из строки
- [0] Выход''')

while True:
    n = input('\n>>> ')

    match n:
        case '1':
            s1 = input('Введите строку: ')
            longest = find_longest_words(s1)
            if longest:
                print(f'Самые длинные слова: {", ".join(longest)}')
            else:
                print('Слов не найдено.')

        case '2':
            s1 = input('Введите первую строку: ')
            s2 = input('Введите вторую строку: ')
            freq_word = find_most_frequent_in_two(s1, s2)
            if freq_word:
                print(f'Слово, встречающееся чаще всего: "{freq_word}"')
            else:
                print('Нет общих слов или строки пусты.')

        case '3':
            s1 = input('Введите первую строку: ')
            s2 = input('Введите вторую строку: ')
            common = find_common_words(s1, s2)
            if common:
                print(f'Общие слова: {", ".join(common)}')
            else:
                print('Общих слов нет.')

        case '4':
            s1 = input('Введите строку: ')
            no_palindromes = remove_palindromes(s1)
            print(f'Строка без палиндромов: "{no_palindromes}"')

        case '0':
            print('Программа завершена.')
            break
