# 3.5 решение СЛАУ тремя способами
print("\n5) Решение СЛАУ:")
A_sys = sp.Matrix([[1, 2, -3, 4], [-1, 0, 1, 2], [3, 4, 5, 0], [5, 6, 7, -2]])
B_sys = sp.Matrix([-13, -1, 11, 19])
detA = A_sys.det()

if detA != 0:
    # а) Метод Крамера (замена i-го столбца на B_sys)
    sol_cr = []
    for i in range(4):
        A_mod = A_sys.copy()
        A_mod[:, i] = B_sys  # Заменяем i-й столбец на вектор свободных членов
        sol_cr.append(A_mod.det() / detA)
    print(f"\tа) Метод Крамера: {sol_cr}")

    # б) Обратная матрица
    X_inv = A_sys.inv() * B_sys
    print(f"\tб) Обратная матрица: {X_inv.T}")
else:
    print("\tа) и б) Определитель = 0, методы не применимы.")

