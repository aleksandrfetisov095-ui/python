print("\n5. ДИФФЕРЕНЦИАЛЬНЫЕ УРАВНЕНИЯ (Вариант 6)")

x = sp.Symbol('x')
y = sp.Function('y')(x)

# 5.1 Общее решение ОДУ: y''' - 6y'' + 11y' - 6y = 0
ode1 = sp.Eq(y.diff(x, 3) - 6*y.diff(x, 2) + 11*y.diff(x) - 6*y, 0)
sol1 = sp.dsolve(ode1, y)
print("\n1) y''' - 6y'' + 11y' - 6y = 0")
print(f"\tОбщее решение: {sol1}")

# 5.2 Частное решение с НУ: y'' + y = sin(x), y(0)=0, y'(0)=1
ode2 = sp.Eq(y.diff(x, 2) + y, sp.sin(x))
ics2 = {y.subs(x, 0): 0, y.diff(x).subs(x, 0): 1}
sol2 = sp.dsolve(ode2, y, ics=ics2)
print(f"\n2) y'' + y = sin(x), y(0)=0, y'(0)=1")
print(f"\tЧастное решение: {sol2}")
p_ode = plot(sol2.rhs, (x, -2, 10), show=False, line_color='blue',
             title='Интегральная кривая', backend='matplotlib')
p_ode.show(); input("Закройте окно графика и нажмите Enter...")

# 5.3 Система ДУ: x'=x+y, y'=x-y
t_sys = sp.Symbol('t')
x_t = sp.Function('x')(t_sys)
y_t = sp.Function('y')(t_sys)
sys_eq = [sp.Eq(x_t.diff(t_sys), x_t + y_t), sp.Eq(y_t.diff(t_sys), x_t - y_t)]
sol_sys = sp.dsolve(sys_eq, [x_t, y_t])
print("\n3) Система: x'=x+y, y'=x-y")
print("\tОбщее решение:")
for s in sol_sys:
    print(f"     {s}")
# Проверка первого уравнения
if sol_sys:
    xs = sol_sys[0].rhs
    ys = sol_sys[1].rhs
    chk = sp.simplify(xs.diff(t_sys) - (ys + xs)) # Note: x_t is xs, y_t is ys
    print(f"\tПроверка x'-(x+y) = {chk} (должно быть 0)")
