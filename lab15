def my_split(stroka):
    result = []
    for char in stroka:
        result.append(char)
    return result
def mozhno_sformirovat(stroka1, stroka2):
    spisok_simvolov = my_split(stroka1)

    for simvol in stroka2:
        if simvol in spisok_simvolov:
            spisok_simvolov.remove(simvol)
        else:
            print(f"РЕЗУЛЬТАТ: Нельзя - не хватает символа '{simvol}'")

    print("РЕЗУЛЬТАТ: Можно составить!")


pervaya = input("Введите первую строку: ")
vtoraya = input("Введите вторую строку: ")

mozhno_sformirovat(pervaya, vtoraya)
