# пп my_split() - Разбиваение строки на список символов
# formation() - возможность составления второй строки из первой
# char,simvol - индексы циклов
#flag - флаг для отслеживания ошибок
# pervaya,vtoraya - переменные для ввода данных
def my_split(stroka):
    result = []
    for char in stroka:
        result.append(char)
    return result

def formation(stroka1, stroka2):
    list1 = my_split(stroka1)
    list2 = my_split(stroka2)
    flag = True

    for simvol in list2:
        if simvol in list1:
            list1.remove(simvol)
        else:
            flag = False
            break
    if flag:
        print("РЕЗУЛЬТАТ: Можно составить!")
    else:
        print(f"РЕЗУЛЬТАТ: Нельзя составить!")

pervaya = input("Введите первую строку: ")
vtoraya = input("Введите вторую строку: ")

formation(pervaya, vtoraya)
