# доп задание
# Выведите все элементы списка с четными индексами. Программа должна быть эффективной
# и не выполнять лишних действий!
#nums - список итоговых чисел
#cur - вспомогательная переменная
#c,i - счетчики цикла

nums = []
cur = ''
for c in input("Введите числа через пробел\n"):
    if c != ' ':
        cur += c
    else:
        nums.append(int(cur))
        cur = ''
nums.append(int(cur))

for i in range(0, len(nums), 2):
    print(nums[i], end=' ')
