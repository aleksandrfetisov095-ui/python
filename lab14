import random
# input_matrix - Подпрограмма ввода матрицы
# output_matrix - Подпрограмма вывода матрицы
# array_sum - Подпрограмма подсчета суммы элементов одномерного массива
# i j x - индексы циклов
# n m - ввод строк и столбцов
def input_matrix(n: int, m: int) -> list[list[int]]:
    matrix = [[0] * m for _ in range(n)]
    for i in range(n):
        for j in range(m):
            matrix[i][j] = random.randint(-10, 10)
    return matrix

def output_matrix(n: int, m: int, matrix: list[list[int]]) -> None:
    print("Матрица:")
    for i in range(n):
        for j in range(m):
            print(f"{matrix[i][j]:5}", end="")
        print()

def array_sum(arr: list[int]) -> int:
    total = 0
    for x in arr:
        total += x
    return total

n = int(input("Введите количество строк: "))
m = int(input("Введите количество столбцов: "))

a = input_matrix(n, m)
output_matrix(n, m, a)

column_sums = []
for j in range(m):
    col = []
    for i in range(n):
        col.append(a[i][j])

    s = array_sum(col)
    
    column_sums.append(s)

print("\nСуммы столбцов:", column_sums)


